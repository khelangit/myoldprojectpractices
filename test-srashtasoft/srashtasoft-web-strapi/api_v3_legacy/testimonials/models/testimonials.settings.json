{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "name": "testimonials"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "person_name": {
      "type": "string",
      "required": true
    },
    "person_tagline": {
      "type": "string",
      "required": true
    },
    "person_img": {
      "model": "file",
      "via": "related",
      "allowedTypes": [
        "images"
      ],
      "plugin": "upload",
      "required": true,
      "pluginOptions": {}
    },
    "content": {
      "type": "text",
      "required": true
    }
  }
}
