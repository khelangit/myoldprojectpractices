{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "name": "blogs",
    "description": ""
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "plugin": "users-permissions",
      "model": "user"
    },
    "blog_title": {
      "type": "text",
      "required": true
    },
    "blog_title_img": {
      "model": "file",
      "via": "related",
      "allowedTypes": [
        "images"
      ],
      "plugin": "upload",
      "required": true,
      "pluginOptions": {}
    },
    "content": {
      "type": "richtext",
      "required": true
    },
    "blog_category": {
      "model": "blog-categories"
    },
    "slug": {
      "type": "string"
    },
    "isPopular": {
      "type": "boolean",
      "default": false,
      "required": true
    }
  }
}
