/* AJAX handler: generate image */
add_action('wp_ajax_afig_generate_image', 'afig_generate_image_callback');
function afig_generate_image_callback(){
    check_ajax_referer('afig_nonce','nonce');

    $post_id = intval($_POST['post_id'] ?? 0);
    if (!$post_id || !current_user_can('edit_post', $post_id)) wp_send_json_error('Permission denied');

    $prompt = wp_strip_all_tags(sanitize_textarea_field($_POST['prompt'] ?? ''));
    if (empty($prompt)) wp_send_json_error('Prompt is empty');

    $size = sanitize_text_field($_POST['size'] ?? '');
    $s = get_option('afig_settings');
    $provider = $s['provider'] ?? 'openai';

    // compute size fallback
    if ($size === 'custom' || empty($size)) $size = $s['default_size'] ?? '1024x1024';
    list($w,$h) = array_map('intval', explode('x',$size));

    // cache key to avoid duplicate calls (transient)
    $cache_key = 'afig_' . md5($provider . '|' . $prompt . '|' . $size);
    if ($cached = get_transient($cache_key)){
        // check attachment exists
        if (isset($cached['attach']) && get_post($cached['attach'])){
            wp_send_json_success(['attachment_id'=>$cached['attach'], 'url'=>wp_get_attachment_url($cached['attach'])]);
        }
    }

    // Call provider
    $image_data = false;
    $mime = 'image/png';
    if ($provider === 'openai'){
        $api_key = $s['openai_key'] ?? '';
        if (empty($api_key)) wp_send_json_error('OpenAI key not configured in settings.');

        $body = [
            "prompt" => $prompt,
            "n" => 1,
            "size" => "{$w}x{$h}"
        ];

        $args = [
            'headers' => [
                'Authorization' => 'Bearer ' . $api_key,
                'Content-Type'  => 'application/json',
            ],
            'body' => json_encode($body),
            'timeout' => 60,
        ];
        $resp = wp_remote_post('https://api.openai.com/v1/images/generations', $args);
        if (is_wp_error($resp)) wp_send_json_error('API request failed: ' . $resp->get_error_message());

        $rb = json_decode(wp_remote_retrieve_body($resp), true);
        // handle b64 or url
        if (!empty($rb['data'][0]['b64_json'])){
            $image_data = base64_decode($rb['data'][0]['b64_json']);
            $mime = 'image/png';
        } elseif (!empty($rb['data'][0]['url'])){
            $file_resp = wp_remote_get($rb['data'][0]['url'], ['timeout'=>60]);
            if (is_wp_error($file_resp)) wp_send_json_error('Failed to download image.');
            $image_data = wp_remote_retrieve_body($file_resp);
            $ct = wp_remote_retrieve_header($file_resp, 'content-type') ?: 'image/png';
            $mime = $ct;
        } else {
            wp_send_json_error('Unexpected response from OpenAI.');
        }
    } elseif ($provider === 'automatic1111'){
        $sd_url = $s['sd_url'] ?? '';
        if (empty($sd_url)) wp_send_json_error('SD URL not configured.');

        // payload for Automatic1111 /sdapi/v1/txt2img
        $payload = [
            'prompt' => $prompt,
            'width' => $w,
            'height' => $h,
            'steps' => 20,
            'cfg_scale' => 7,
        ];
        $args = [
            'headers' => ['Content-Type' => 'application/json'],
            'body' => json_encode($payload),
            'timeout' => 120,
        ];
        $resp = wp_remote_post($sd_url, $args);
        if (is_wp_error($resp)) wp_send_json_error('SD API request failed: ' . $resp->get_error_message());
        $rb = json_decode(wp_remote_retrieve_body($resp), true);
        if (!empty($rb['images'][0])){
            $image_data = base64_decode($rb['images'][0]);
            $mime = 'image/png';
        } else {
            wp_send_json_error('Unexpected SD response.');
        }
    } else {
        wp_send_json_error('Unknown provider.');
    }

    if (!$image_data) wp_send_json_error('Image data missing.');

    // Save to uploads
    $upload = wp_upload_bits('ai-image-' . time() . '.png', null, $image_data);
    if ($upload['error']) wp_send_json_error('Upload error: ' . $upload['error']);

    $file = $upload['file'];
    $filetype = wp_check_filetype($file, null);

    // Optional resize/compress
    $resize_to = $s['resize_to'] ?? '';
    $quality = intval($s['quality'] ?? 90);
    if (!empty($resize_to) && $editor = wp_get_image_editor($file) && !is_wp_error($editor)){
        list($rw,$rh) = array_map('intval', explode('x',$resize_to));
        if ($rw && $rh){
            $editor->resize($rw, $rh, true);
        }
        if (method_exists($editor,'set_quality')) $editor->set_quality($quality);
        $saved = $editor->save($file);
        if (!is_wp_error($saved)) {
            // ok
        }
    }

    // Insert attachment
    $attachment = [
        'post_mime_type' => $filetype['type'] ?: $mime,
        'post_title' => sanitize_file_name(basename($file)),
        'post_content' => '',
        'post_status' => 'inherit',
    ];

    require_once(ABSPATH . 'wp-admin/includes/image.php');
    require_once(ABSPATH . 'wp-admin/includes/file.php');
    require_once(ABSPATH . 'wp-admin/includes/media.php');

    $attach_id = wp_insert_attachment($attachment, $file, 0);
    if (is_wp_error($attach_id) || !$attach_id) wp_send_json_error('Failed to insert attachment.');

    $attach_data = wp_generate_attachment_metadata($attach_id, $file);
    wp_update_attachment_metadata($attach_id, $attach_data);

    // mark meta for reuse
    update_post_meta($attach_id, 'afig_generated', 1);
    update_post_meta($attach_id, 'afig_prompt', $prompt);
    update_post_meta($attach_id, 'afig_provider', $provider);

    // auto assign?
    if (!empty($s['auto_assign'])){
        set_post_thumbnail($post_id, $attach_id);
    }

    // cache mapping 7 days
    set_transient($cache_key, ['attach' => $attach_id], DAY_IN_SECONDS * 7);

    wp_send_json_success(['attachment_id' => $attach_id, 'url' => wp_get_attachment_url($attach_id)]);
}

/* Optional: AJAX to set existing attachment as featured (for library listing) */
add_action('wp_ajax_afig_set_featured', function(){
    check_ajax_referer('afig_nonce','nonce');
    $post_id = intval($_POST['post_id'] ?? 0);
    $attach = intval($_POST['attach'] ?? 0);
    if (!$post_id || !$attach || !current_user_can('edit_post',$post_id)) wp_send_json_error('Permission');
    set_post_thumbnail($post_id, $attach);
    wp_send_json_success();
});
