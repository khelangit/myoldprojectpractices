function afig_sanitize_settings($in){
    $out = array();
    $out['provider'] = in_array($in['provider'], ['openai','automatic1111']) ? $in['provider'] : 'openai';
    $out['openai_key'] = sanitize_text_field($in['openai_key']);
    $out['sd_url'] = esc_url_raw($in['sd_url']);
    $out['sd_api_key'] = sanitize_text_field($in['sd_api_key']);
    $out['default_size'] = sanitize_text_field($in['default_size']);
    $out['resize_to'] = sanitize_text_field($in['resize_to']);
    $out['quality'] = intval($in['quality']);
    $out['auto_assign'] = !empty($in['auto_assign']) ? 1 : 0;
    $out['save_to_library'] = !empty($in['save_to_library']) ? 1 : 0;
    return $out;
}

